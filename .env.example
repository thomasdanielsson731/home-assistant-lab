# Copy to .env and fill in values. This file is safe to commit.
HA_HOST=192.168.1.50
HA_USER=root
HA_SSH_PORT=22222
HA_CONFIG_PATH=/config

# Camera credentials (used by scripts/configure_cameras.py)
CAM_USER=homeassistant
CAM_PASS=change-me

# MQTT credentials (used by scripts/configure_cameras.py)
MQTT_USER=frigate
MQTT_PASS=change-me

# Optional: HA long-lived access token for lightweight YAML reload
# Create in HA: Profile → Security → Long-Lived Access Tokens
# HA_TOKEN=your-token-here
