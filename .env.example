# Copy to .env and fill in values. This file is safe to commit.
HA_HOST=192.168.1.50
HA_USER=root
HA_SSH_PORT=22222
HA_CONFIG_PATH=/config

# Camera credentials (used by scripts/configure_cameras.py)
CAM_USER=homeassistant
CAM_PASS=change-me

# Root credentials — required by scripts/audio_bridge.py (WebSocket SPL stream)
# AXIS_ROOT_USER=root
# AXIS_ROOT_PASSWORD=change-me

# MQTT credentials (used by scripts/configure_cameras.py)
MQTT_USER=frigate
MQTT_PASS=change-me

# Optional: HA long-lived access token for lightweight YAML reload
# Create in HA: Profile → Security → Long-Lived Access Tokens
# HA_TOKEN=your-token-here

# Family local users (scripts/create_ha_users.py, scripts/configure_ha_family_users.py)
# HA_FAMILY_PASSWORD=choose-a-shared-or-per-user-password

# Yale / HA lock entities for door events (entity_suffix:zone)
# YALE_LOCK_ENTITIES=front_door:front,yale_doorman:front

# ZHA smoke detectors for timeline events (entity_suffix:zone)
# Indoor temperature → metrics.jsonl + Environment charts (entity_suffix:zone)
# Run: python scripts/probe_smoke_entities.py  (after pairing + Areas assigned)
# SMOKE_ENTITIES=heiman_hs1sa_e_plus_ias_zon_2:vardagsrum,heiman_hs1sa_e_plus_ias_zon:hall,heiman_hs1sa_e_plus:kok
# INDOOR_TEMP_ENTITIES=heiman_hs1sa_e_plus_temperatur_3:vardagsrum,heiman_hs1sa_e_plus_temperatur_2:hall,heiman_hs1sa_e_plus_temperatur:kok
# Optional: Ollama local LLM for story_engine ai_summary
# OLLAMA_URL=http://192.168.68.136:11434
# OLLAMA_MODEL=qwen2.5

# Baseline / anomaly engine (baseline_engine.py in Insights add-on)
# BASELINE_DAYS=14
# BASELINE_SIGMA=2.0

# Dev PC LAN IP — timeline iframe in HA (run .\scripts\update-timeline-url.ps1)
# DEV_PC_HOST=192.168.68.136

# InfluxDB metrics retention (influx_metrics_bridge.py) — add-on on HAOS :8086
# INFLUX_URL=http://192.168.68.175:8086
# INFLUX_V2=false
# INFLUX_DB=home_lab
# INFLUX_USER=homelab
# INFLUX_PASSWORD=change-me
# INFLUX_MEASUREMENT=home_metrics
