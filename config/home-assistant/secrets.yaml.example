# Copy this file to secrets.yaml on the HA host — never commit secrets.yaml itself.
# Key pattern: <zone_id>_camera_<attribute>

home_latitude: "59.0"
home_longitude: "18.0"
home_elevation: "10"

# Camera credentials — one set per zone (all cameras share the same user/pass in this lab)
front_camera_user: "homeassistant"
front_camera_password: "changeme"
front_camera_ip: "192.168.68.200"

driveway_wide_camera_user: "homeassistant"
driveway_wide_camera_password: "changeme"
driveway_wide_camera_ip: "192.168.68.203"

driveway_id_camera_user: "homeassistant"
driveway_id_camera_password: "changeme"
driveway_id_camera_ip: "192.168.68.204"

backyard_camera_user: "homeassistant"
backyard_camera_password: "changeme"
backyard_camera_ip: "192.168.68.202"

storage_ext_camera_user: "homeassistant"
storage_ext_camera_password: "changeme"
storage_ext_camera_ip: "192.168.68.205"

storage_int_camera_user: "homeassistant"
storage_int_camera_password: "changeme"
storage_int_camera_ip: "192.168.68.206"

# MQTT (Frigate, bridges)
mqtt_username: "frigate"
mqtt_password: "changeme"

# House Intelligence — Analytics / Environment dashboard URLs
# HAOS add-on (recommended — direct port, no Ingress 401 in iframe):
#   .\scripts\deploy-insights-to-ha.ps1 -UseDirectSecrets
#   .\scripts\verify-insights-ha.ps1
timeline_url: "http://192.168.68.175:8765/timeline"
environment_url: "http://192.168.68.175:8765/environment"
# Dev PC fallback: .\scripts\update-timeline-url.ps1
# timeline_url: "http://192.168.68.136:8765/timeline"
# Ingress (Lovelace iframe often 401 — use add-on sidebar panel instead):
# timeline_url: "/api/hassio_ingress/<token>/timeline"
#   .\scripts\deploy-insights-to-ha.ps1 -UseIngressSecrets
